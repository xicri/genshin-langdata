{
  "name": "genshin-langdata",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.js",
    "todo": "node scripts/todo.js",
    "test": "pnpm run build && vitest run",
    "lint": "find ./dataset/ -name *.json5 | xargs json5 --validate && eslint --ext .js,.mjs,.cjs,.ts,.json,.json5 --ignore-path .gitignore .",
    "clean": "git clean -dX --exclude=\"!.env\" --force",
    "refresh": "pnpm run clean && rm --force ./pnpm-lock.yaml && corepack up && pnpm install",
    "release": "./scripts/release.sh"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "eslint": "^8.57.1",
    "eslint-config-xicri": "latest",
    "iconv-lite": "^0.6.3",
    "json5": "^2.2.2",
    "klona": "^2.0.4",
    "lodash-es": "^4.17.21",
    "luxon": "^3.5.0",
    "marked": "^15.0.4",
    "node-fetch": "^3.2.4",
    "pinyin-tone": "^2.2.4",
    "vitest": "^2.1.8",
    "wrangler": "^3.99.0"
  },
  "engines": {
    "node": "22.x",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.2+sha512.93e57b0126f0df74ce6bff29680394c0ba54ec47246b9cf321f0121d8d9bb03f750a705f24edc3c1180853afd7c2c3b94196d0a3d53d3e069d9e2793ef11f321"
}
